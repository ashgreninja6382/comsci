#include <SFML/Graphics.hpp>
#include <cmath>
#include <algorithm>
#include <optional>

using namespace std;

int main()
{
    sf::RenderWindow window(sf::VideoMode({600, 800}),
                            "Super Pickleball Adventure");

    window.setFramerateLimit(60);

    // FIELD
    sf::RectangleShape field({600.f, 800.f});
    field.setFillColor(sf::Color(34, 100, 34));

    // COURT
    sf::RectangleShape court({400.f, 600.f});
    court.setFillColor(sf::Color(150, 180, 150));
    court.setOutlineColor(sf::Color::White);
    court.setOutlineThickness(3.f);
    court.setPosition({100.f, 100.f});

    sf::RectangleShape netLine({400.f, 10.f});
    netLine.setFillColor(sf::Color::White);
    netLine.setPosition({100.f, 395.f});

    sf::RectangleShape midLine({3.f, 600.f});
    midLine.setFillColor(sf::Color::White);
    midLine.setPosition({300.f, 100.f});

    // PLAYERS
    sf::RectangleShape p1({30.f, 40.f});
    p1.setFillColor(sf::Color::Red);
    p1.setOrigin({15.f, 20.f});
    p1.setPosition({395.f, 680.f});

    sf::RectangleShape p2({30.f, 40.f});
    p2.setFillColor(sf::Color(128, 0, 200));
    p2.setOrigin({15.f, 20.f});
    p2.setPosition({200.f, 120.f});

    // BALL
    sf::CircleShape ball(12.f);
    ball.setFillColor(sf::Color::White);
    ball.setOutlineColor(sf::Color::Black);
    ball.setOutlineThickness(2.f);
    ball.setOrigin({12.f, 12.f});
    ball.setPosition({395.f, 650.f});

    float ballVx = 0.f;
    float ballVy = 0.f;

    // CURVE SYSTEM
    float curveForce     = 0.f;   // pixels/s^2 acceleration applied after trigger
    float curveTriggerY  = 0.f;   // Y threshold at which curve kicks in
    bool  curveActive    = false;  // is a curve pending?
    bool  curveTriggered = false;  // has the curve already fired?
    float curveDirX      = 0.f;   // -1 left, +1 right, 0 straight

    bool ballInPlay = false;
    bool ballOwner  = true;
    bool serving    = true;

    // Out-of-bounds tracking
    // Ball is "in opponent's half" once it crosses net toward them
    // Left/right OOB only penalises if ball hasn't reached opponent's half yet
    const float courtLeft  = 100.f;   // court inner left  (outline at 100)
    const float courtRight = 500.f;   // court inner right (100 + 400)
    const float oobLeft    = 45.f;    // hard OOB left wall
    const float oobRight   = 555.f;   // hard OOB right wall

    // SPEEDS
    const float playerSpeed = 250.f;
    const float dashSpeed   = 700.f;
    const float dashTime    = 0.15f;

    // DASH
    bool  p1Dashing   = false;
    bool  p2Dashing   = false;
    float p1DashTimer = 0.f;
    float p2DashTimer = 0.f;
    float p1DashDirX  = 0.f;
    float p1DashDirY  = 0.f;
    float p2DashDirX  = 0.f;
    float p2DashDirY  = 0.f;

    // SWING
    bool  p1Swinging    = false;
    bool  p2Swinging    = false;
    float p1SwingTimer  = 0.f;
    float p2SwingTimer  = 0.f;
    const float swingDuration = 0.25f;

    // Capture which direction the swing was initiated with
    float p1SwingDirX = 0.f;
    float p2SwingDirX = 0.f;

    // HIT COOLDOWN
    float p1HitCooldown = 0.f;
    float p2HitCooldown = 0.f;
    const float hitCooldown = 0.3f;

    // DEAD ZONES
    const float deadZoneTop    = 20.f;
    const float deadZoneBottom = 780.f;

    // FIELD BOUNDS
    const float fieldLeft  = 20.f;
    const float fieldRight = 580.f;

    int score1 = 0;
    int score2 = 0;

    // FONT
    sf::Font font;
    font.openFromFile("C:/Windows/Fonts/arial.ttf");

    sf::Text score1Text(font, "P1: 0", 28);
    score1Text.setFillColor(sf::Color::White);
    score1Text.setPosition({20.f, 730.f});

    sf::Text score2Text(font, "P2: 0", 28);
    score2Text.setFillColor(sf::Color::White);
    score2Text.setPosition({420.f, 20.f});

    sf::Text serveText(font, "X to Serve (P1)", 20);
    serveText.setFillColor(sf::Color::Yellow);
    serveText.setPosition({180.f, 760.f});

    // SWING EFFECTS
    sf::CircleShape p1SwingCircle(35.f);
    p1SwingCircle.setFillColor(sf::Color(255, 255, 0, 120));
    p1SwingCircle.setOrigin({35.f, 35.f});

    sf::CircleShape p2SwingCircle(35.f);
    p2SwingCircle.setFillColor(sf::Color(0, 200, 255, 120));
    p2SwingCircle.setOrigin({35.f, 35.f});

    // ----------------------------------------------------------------
    // Helper: reset ball after a point
    // ----------------------------------------------------------------
    auto resetAfterPoint = [&](bool ownerIsP1)
    {
        ballInPlay = false;
        ballOwner  = ownerIsP1;
        serving    = true;
        ballVx = 0.f;
        ballVy = 0.f;
        curveActive    = false;
        curveTriggered = false;
        curveForce     = 0.f;
        curveDirX      = 0.f;

        if (ownerIsP1)
        {
            p1.setPosition({395.f, 680.f});
            serveText.setString("X to Serve (P1)");
            serveText.setPosition({180.f, 760.f});
        }
        else
        {
            p2.setPosition({200.f, 120.f});
            serveText.setString(". to Serve (P2)");
            serveText.setPosition({190.f, 20.f});
        }
    };

    // ----------------------------------------------------------------
    // HIT helpers  — now store curve info, don't apply immediately
    // ----------------------------------------------------------------
    // P1 hits upward toward P2
    auto hitToP2Field = [&](float dirX, bool dashing)
    {
        float power = dashing ? 560.f : 420.f;

        auto ballPos = ball.getPosition();

        // Small initial lateral push
        ballVx = dirX * 60.f;
        ballVy = -power;

        // Curve triggers at y = 300 (midway in opponent's half)
        curveDirX      = dirX;          // 0 = straight
        curveTriggerY  = 300.f;
        curveForce     = 160.f;         // acceleration magnitude (px/s per s)
        curveActive    = (dirX != 0.f);
        curveTriggered = false;

        ballInPlay = true;
    };

    // P2 hits downward toward P1
    auto hitToP1Field = [&](float dirX, bool dashing)
    {
        float power = dashing ? 560.f : 420.f;

        auto ballPos = ball.getPosition();

        ballVx = dirX * 60.f;
        ballVy = power;

        // Curve triggers at y = 500 (midway in opponent's half)
        curveDirX      = dirX;
        curveTriggerY  = 500.f;
        curveForce     = 160.f;
        curveActive    = (dirX != 0.f);
        curveTriggered = false;

        ballInPlay = true;
    };

    sf::Text p1PosText(font, "P1 (0, 0)", 16);
    p1PosText.setFillColor(sf::Color::Yellow);
    p1PosText.setPosition({10.f, 710.f});

    sf::Text p2PosText(font, "P2 (0, 0)", 16);
    p2PosText.setFillColor(sf::Color::Cyan);
    p2PosText.setPosition({10.f, 20.f});

    sf::Clock clock;

    while (window.isOpen())
    {
        float dt = clock.restart().asSeconds();

        if (p1HitCooldown > 0.f) p1HitCooldown -= dt;
        if (p2HitCooldown > 0.f) p2HitCooldown -= dt;

        // ── EVENTS ──────────────────────────────────────────────────
        while (const optional event = window.pollEvent())
        {
            if (event->is<sf::Event::Closed>())
                window.close();

            if (const auto* key = event->getIf<sf::Event::KeyPressed>())
            {
                // P1 SERVE
                if (key->code == sf::Keyboard::Key::X &&
                    !ballInPlay && ballOwner)
                {
                    float dirX = 0.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::A)) dirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::D)) dirX =  1.f;

                    ballInPlay = true;
                    serving    = false;
                    ballVx = dirX * 80.f;
                    ballVy = -420.f;

                    // Serves are straight
                    curveActive    = false;
                    curveTriggered = false;
                    curveDirX      = 0.f;

                    serveText.setString("");
                }

                // P2 SERVE
                if (key->code == sf::Keyboard::Key::Period &&
                    !ballInPlay && !ballOwner)
                {
                    float dirX = 0.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Left))  dirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Right)) dirX =  1.f;

                    ballInPlay = true;
                    serving    = false;
                    ballVx = dirX * 80.f;
                    ballVy = 420.f;

                    curveActive    = false;
                    curveTriggered = false;
                    curveDirX      = 0.f;

                    serveText.setString("");
                }

                // P1 DASH
                if (key->code == sf::Keyboard::Key::Q &&
                    !p1Dashing && ballInPlay)
                {
                    p1Dashing    = true;
                    p1DashTimer  = dashTime;
                    p1DashDirX   = 0.f;
                    p1DashDirY   = 0.f;

                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::A)) p1DashDirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::D)) p1DashDirX =  1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::W)) p1DashDirY = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::S)) p1DashDirY =  1.f;
                    if (p1DashDirX == 0.f && p1DashDirY == 0.f) p1DashDirY = -1.f;
                }

                // P2 DASH
                if (key->code == sf::Keyboard::Key::RShift &&
                    !p2Dashing && ballInPlay)
                {
                    p2Dashing    = true;
                    p2DashTimer  = dashTime;
                    p2DashDirX   = 0.f;
                    p2DashDirY   = 0.f;

                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Left))  p2DashDirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Right)) p2DashDirX =  1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Up))    p2DashDirY = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Down))  p2DashDirY =  1.f;
                    if (p2DashDirX == 0.f && p2DashDirY == 0.f) p2DashDirY = 1.f;
                }

                // P1 SWING — capture direction at swing start
                if (key->code == sf::Keyboard::Key::Z && !p1Swinging)
                {
                    p1Swinging   = true;
                    p1SwingTimer = swingDuration;
                    p1SwingDirX  = 0.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::A)) p1SwingDirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::D)) p1SwingDirX =  1.f;
                }

                // P2 SWING — capture direction at swing start
                if (key->code == sf::Keyboard::Key::Slash && !p2Swinging)
                {
                    p2Swinging   = true;
                    p2SwingTimer = swingDuration;
                    p2SwingDirX  = 0.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Left))  p2SwingDirX = -1.f;
                    if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Right)) p2SwingDirX =  1.f;
                }
            }
        }

        // ── P1 MOVEMENT ─────────────────────────────────────────────
        if (!p1Dashing)
        {
            float vx = 0.f, vy = 0.f;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::A)) vx = -playerSpeed;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::D)) vx =  playerSpeed;
            if (!ballOwner || ballInPlay)
            {
                if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::W)) vy = -playerSpeed;
                if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::S)) vy =  playerSpeed;
            }
            p1.move({vx * dt, vy * dt});
        }
        else
        {
            p1DashTimer -= dt;
            p1.move({p1DashDirX * dashSpeed * dt, p1DashDirY * dashSpeed * dt});
            if (p1DashTimer <= 0.f) p1Dashing = false;
        }

        // ── P2 MOVEMENT ─────────────────────────────────────────────
        if (!p2Dashing)
        {
            float vx = 0.f, vy = 0.f;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Left))  vx = -playerSpeed;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Right)) vx =  playerSpeed;
            if (ballOwner || ballInPlay)
            {
                if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Up))   vy = -playerSpeed;
                if (sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Down)) vy =  playerSpeed;
            }
            p2.move({vx * dt, vy * dt});
        }
        else
        {
            p2DashTimer -= dt;
            p2.move({p2DashDirX * dashSpeed * dt, p2DashDirY * dashSpeed * dt});
            if (p2DashTimer <= 0.f) p2Dashing = false;
        }

        // ── CLAMP PLAYERS ───────────────────────────────────────────
        auto pos1 = p1.getPosition();
        pos1.x = clamp(pos1.x, fieldLeft, fieldRight);
        pos1.y = clamp(pos1.y, 400.f, deadZoneBottom - 20.f);
        p1.setPosition(pos1);

        auto pos2 = p2.getPosition();
        pos2.x = clamp(pos2.x, fieldLeft, fieldRight);
        pos2.y = clamp(pos2.y, deadZoneTop + 20.f, 400.f);
        p2.setPosition(pos2);

        // ── SWING TIMERS ────────────────────────────────────────────
        if (p1Swinging) { p1SwingTimer -= dt; if (p1SwingTimer <= 0.f) p1Swinging = false; }
        if (p2Swinging) { p2SwingTimer -= dt; if (p2SwingTimer <= 0.f) p2Swinging = false; }

        // ── BALL FOLLOW (before serve) ───────────────────────────────
        if (!ballInPlay)
        {
            if (ballOwner)
                ball.setPosition({p1.getPosition().x, p1.getPosition().y - 30.f});
            else
                ball.setPosition({p2.getPosition().x, p2.getPosition().y + 30.f});
        }

        // ── BALL PHYSICS ─────────────────────────────────────────────
        if (ballInPlay)
        {
            auto bpos = ball.getPosition();

            // ── CURVE: check trigger threshold ───────────────────────
            if (curveActive && !curveTriggered)
            {
                // Ball moving up (P1 hit) — trigger when crossing y=300 downward in Y coords
                bool fromP1 = (ballVy < 0.f) && (bpos.y <= curveTriggerY);
                // Ball moving down (P2 hit) — trigger when crossing y=500
                bool fromP2 = (ballVy > 0.f) && (bpos.y >= curveTriggerY);

                if (fromP1 || fromP2)
                    curveTriggered = true;
            }

            // Apply smooth lateral acceleration after trigger
            if (curveTriggered && curveDirX != 0.f)
            {
                // Gradually ramp up lateral velocity; cap to avoid wild shots
                ballVx += curveDirX * curveForce * dt;
                ballVx  = clamp(ballVx, -260.f, 260.f);
            }

            // Speed cap on vertical
            ballVy = clamp(ballVy, -600.f, 600.f);

            // Move ball
            float nextX = bpos.x + ballVx * dt;
            float nextY = bpos.y + ballVy * dt;

            ball.setPosition({nextX, nextY});
            bpos = ball.getPosition();

            // ── TOP/BOTTOM SCORE ─────────────────────────────────────
            if (bpos.y < deadZoneTop)
            {
                score1++;
                score1Text.setString("P1: " + to_string(score1));
                resetAfterPoint(false);   // P2 serves next
            }
            else if (bpos.y > deadZoneBottom)
            {
                score2++;
                score2Text.setString("P2: " + to_string(score2));
                resetAfterPoint(true);    // P1 serves next
            }
            else
            {
                // ── LEFT / RIGHT OUT-OF-BOUNDS SCORING ───────────────
                //
                // Determine which "half" the ball is currently in.
                // P1's half: y > 400  (bottom)
                // P2's half: y < 400  (top)
                //
                // If the ball exits the court sideways while still
                // in the hitter's own half it is immediately out.
                // Once it crosses into the opponent's half it may
                // drift outside the strict court lines — it is only
                // called out if it passes the hard oobLeft/oobRight walls.

                bool inP1Half = (bpos.y > 400.f);   // P1 is at bottom
                bool inP2Half = (bpos.y < 400.f);   // P2 is at top

                // Ball travelling upward was hit by P1; travelling downward by P2.
                // "Crossed net" means it is already in the opponent's half.
                bool hitByP1CrossedNet = (ballVy < 0.f) && inP2Half;
                bool hitByP2CrossedNet = (ballVy > 0.f) && inP1Half;
                bool crossedNet        = hitByP1CrossedNet || hitByP2CrossedNet;

                bool oobSide = false;

                if (crossedNet)
                {
                    // In opponent territory — only hard walls apply
                    oobSide = (bpos.x < oobLeft || bpos.x > oobRight);
                }
                else
                {
                    // Still in hitter's own half — court edge applies immediately
                    oobSide = (bpos.x < courtLeft || bpos.x > courtRight);
                }

                if (oobSide)
                {
                    // Determine who hit it last (direction of travel tells us)
                    // If ball is going up (negative Y) → P1 hit it → P2 scores
                    // If ball is going down (positive Y) → P2 hit it → P1 scores
                    if (ballVy < 0.f)
                    {
                        // P1's fault
                        score2++;
                        score2Text.setString("P2: " + to_string(score2));
                        resetAfterPoint(true);   // P1 serves (lost the point)
                    }
                    else
                    {
                        // P2's fault
                        score1++;
                        score1Text.setString("P1: " + to_string(score1));
                        resetAfterPoint(false);  // P2 serves (lost the point)
                    }
                }
            }

            // ── HIT DETECTION (only run if ball still in play) ───────
            if (ballInPlay)
            {
                sf::FloatRect ballB = ball.getGlobalBounds();

                sf::FloatRect p1Hit = p1.getGlobalBounds();
                p1Hit.position.x -= 20.f; p1Hit.position.y -= 20.f;
                p1Hit.size.x     += 40.f; p1Hit.size.y     += 40.f;

                sf::FloatRect p2Hit = p2.getGlobalBounds();
                p2Hit.position.x -= 20.f; p2Hit.position.y -= 20.f;
                p2Hit.size.x     += 40.f; p2Hit.size.y     += 40.f;

                // P1 HIT
                bool p1CanHit =
                    (p1Swinging || p1Dashing) &&
                    p1HitCooldown <= 0.f &&
                    ball.getPosition().y > 400.f;

                if (p1CanHit && ballB.findIntersection(p1Hit))
                {
                    // Use the direction captured at swing start (or dash direction)
                    float dirX = p1Dashing ? p1DashDirX : p1SwingDirX;
                    hitToP2Field(dirX, p1Dashing);
                    p1Swinging    = false;
                    p1HitCooldown = hitCooldown;
                }

                // P2 HIT
                bool p2CanHit =
                    (p2Swinging || p2Dashing) &&
                    p2HitCooldown <= 0.f &&
                    ball.getPosition().y < 400.f;

                if (p2CanHit && ballB.findIntersection(p2Hit))
                {
                    float dirX = p2Dashing ? p2DashDirX : p2SwingDirX;
                    hitToP1Field(dirX, p2Dashing);
                    p2Swinging    = false;
                    p2HitCooldown = hitCooldown;
                }
            }
        }

        // ── DRAW ─────────────────────────────────────────────────────
        window.clear();

        window.draw(field);
        window.draw(court);
        window.draw(midLine);
        window.draw(netLine);

        if (p1Swinging)
        {
            p1SwingCircle.setPosition(p1.getPosition());
            window.draw(p1SwingCircle);
        }
        if (p2Swinging)
        {
            p2SwingCircle.setPosition(p2.getPosition());
            window.draw(p2SwingCircle);
        }

        window.draw(p1);
        window.draw(p2);
        window.draw(ball);

        window.draw(score1Text);
        window.draw(score2Text);
        window.draw(serveText);

        p1PosText.setString("P1 (" + to_string((int)p1.getPosition().x) +
                            ", "   + to_string((int)p1.getPosition().y) + ")");
        p2PosText.setString("P2 (" + to_string((int)p2.getPosition().x) +
                            ", "   + to_string((int)p2.getPosition().y) + ")");

        window.draw(p1PosText);
        window.draw(p2PosText);

        window.display();
    }
}
